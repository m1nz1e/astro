---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>M1nz · AI Projects</title>
  <link href="https://cdn.jsdelivr.net/npm/@n8n/chat/style.css" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #4a63e7;
      --primary-dark: #2e47cc;
      --bg: #f9f9f9;
      --surface: #ffffff;
      --border: #e4e4e4;
      --text: #1a1a1a;
      --muted: #666;
      --success: #16a34a;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111;
        --surface: #1c1c1e;
        --border: #2a2a2a;
        --text: #f0f0f0;
        --muted: #888;
      }
    }
    body { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }

    /* Header */
    header { display: flex; justify-content: space-between; align-items: center; padding: 14px 32px; background: var(--surface); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
    .logo { font-weight: 600; font-size: 16px; display: flex; align-items: center; gap: 8px; }
    .logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary); }
    nav { display: flex; gap: 24px; }
    nav a { font-size: 14px; color: var(--muted); text-decoration: none; transition: color 0.15s; }
    nav a:hover { color: var(--text); }

    /* Hero */
    .hero { padding: 72px 32px 56px; text-align: center; background: var(--surface); border-bottom: 1px solid var(--border); }
    .badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--primary); background: #eff2ff; border: 1px solid #c7d0fb; border-radius: 20px; padding: 4px 12px; margin-bottom: 20px; }
    .hero h1 { font-size: 2.4rem; font-weight: 700; margin-bottom: 14px; letter-spacing: -0.5px; }
    .hero p { font-size: 1.05rem; color: var(--muted); max-width: 500px; margin: 0 auto 28px; }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 12px 24px; font-size: 15px; font-weight: 500; cursor: pointer; transition: background 0.15s; text-decoration: none; }
    .cta-btn:hover { background: var(--primary-dark); }

    /* Main */
    main { max-width: 860px; margin: 0 auto; padding: 48px 24px; }
    section { margin-bottom: 48px; }
    h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: 20px; }

    /* Feature grid */
    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; }
    .feat { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 16px; }
    .feat-icon { font-size: 22px; margin-bottom: 8px; }
    .feat strong { display: block; font-size: 14px; margin-bottom: 4px; }
    .feat span { font-size: 13px; color: var(--muted); }

    /* About */
    .about-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; display: flex; gap: 16px; align-items: flex-start; }
    .avatar { width: 46px; height: 46px; border-radius: 50%; background: #eff2ff; color: var(--primary); font-weight: 600; font-size: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .about-card p { font-size: 14px; color: var(--muted); }
    .about-card strong { display: block; font-weight: 600; margin-bottom: 6px; }

    /* Examples */
    .examples { display: flex; flex-direction: column; gap: 8px; }
    .example-pill { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px; font-size: 13px; color: var(--muted); cursor: pointer; text-align: left; transition: border-color 0.15s, color 0.15s; }
    .example-pill:hover { border-color: var(--primary); color: var(--text); }

    /* Footer */
    footer { text-align: center; padding: 24px; border-top: 1px solid var(--border); font-size: 13px; color: var(--muted); }

    /* n8n chat widget fixes */
    .n8n-chat-window {
      width: 520px !important;
      max-width: 90vw !important;
    }
    .n8n-chat-messages-list {
      font-size: 14px;
      line-height: 1.6;
    }
    .n8n-chat-message-text table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      display: block;
      overflow-x: auto;
      white-space: nowrap;
      margin-top: 8px;
    }
    .n8n-chat-message-text th {
      background: #4a63e7;
      color: #fff;
      padding: 8px 12px;
      text-align: left;
      font-weight: 500;
      white-space: nowrap;
    }
    .n8n-chat-message-text td {
      padding: 7px 12px;
      border-bottom: 1px solid #e4e4e4;
      white-space: nowrap;
    }
    .n8n-chat-message-text tr:nth-child(even) td {
      background: rgba(74, 99, 231, 0.05);
    }
    .n8n-chat-message-text pre {
      white-space: pre-wrap;
      word-break: break-word;
    }
    .n8n-chat-message-text img {
      max-width: 100%;
      height: auto;
    }
  </style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-dot"></div>
    M1nz · AI Projects
  </div>
  <nav>
    <a href="#about">About</a>
    <a href="#chatbot">Chatbot</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<div class="hero">
  <div class="badge">✦ UCL AI Data Engineering Apprentice</div>
  <h1>Student data,<br/>answered instantly</h1>
  <p>A production RAG chatbot built on n8n, Qdrant, and Ollama. Ask about grades, cohorts, and performance in plain English.</p>
  <a href="#chatbot" class="cta-btn">💬 Try the chatbot</a>
</div>

<main>
  <section>
    <h2>What it can do</h2>
    <div class="features">
      <div class="feat">
        <div class="feat-icon">🗄️</div>
        <strong>RAG queries</strong>
        <span>Retrieves live student data via vector search</span>
      </div>
      <div class="feat">
        <div class="feat-icon">📊</div>
        <strong>Auto charts</strong>
        <span>Visualisations generated on demand</span>
      </div>
      <div class="feat">
        <div class="feat-icon">💬</div>
        <strong>Natural language</strong>
        <span>Ask in plain English, no SQL needed</span>
      </div>
      <div class="feat">
        <div class="feat-icon">⚡</div>
        <strong>Real-time</strong>
        <span>Powered by n8n workflow automation</span>
      </div>
    </div>
  </section>

  <section id="chatbot">
    <h2>Try some questions</h2>
    <div class="examples">
      <button class="example-pill" onclick="openChat('How many students enrolled for 2024 cohort?')">📈 What is the average grade for the 2024 cohort?</button>
      <button class="example-pill" onclick="openChat('Show me the % change in student enrolments')">🏆 Show me the top performing students</button>
      <button class="example-pill" onclick="openChat('Compare pass rates between departments')">📊 Compare pass rates between departments</button>
      <button class="example-pill" onclick="openChat('What is the overall pass rate this year?')">✅ What is the overall pass rate this year?</button>
    </div>
  </section>

  <section id="about">
    <h2>About</h2>
    <div class="about-card">
      <div class="avatar">MH</div>
      <div>
        <strong>Minesh Halai</strong>
        <p>AI Data Engineering apprentice at UCL, building production-grade ML and RAG systems. This site showcases projects built during my Level 6 Machine Learning Engineer Degree Apprenticeship at Cambridge Spark.</p>
      </div>
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p style="color: var(--muted); font-size: 14px;">Use the chat button below to ask questions, or reach out via <a href="mailto:minesh@m1nz.org" style="color: var(--primary);">minesh@m1nz.org</a>.</p>
  </section>
</main>

<footer>
  &copy; <span id="yr"></span> Minesh Halai · UCL Student &amp; Registry Services
</footer>

<script>
  document.getElementById('yr').textContent = new Date().getFullYear();
  function openChat(msg) {
    const btn = document.querySelector('.n8n-chat-toggle-button');
    if (btn) { btn.click(); }
    setTimeout(() => {
      const input = document.querySelector('.n8n-chat-input textarea, .n8n-chat-input input');
      if (input) { input.value = msg; input.dispatchEvent(new Event('input', { bubbles: true })); input.focus(); }
    }, 400);
  }
</script>

<script type="module">
  import { createChat } from 'https://cdn.jsdelivr.net/npm/@n8n/chat/chat.bundle.es.js';
  createChat({
    webhookUrl: 'https://n8n1.m1nz.org/webhook/5e56a263-3a40-44bd-bc9d-1cfb3bc2a87d/chat',
    mode: 'window',
    showWelcomeScreen: false,
    defaultLanguage: 'en',
    initialMessages: [
      'Hello! 👋',
      'I\'m your Student Data Bot for UCL. Ask me anything student enrolments at UCL. I\'m an AI and can make mistakes.'
    ],
    theme: { primaryColor: '#4a63e7' }
  });
</script>

</body>
</html>
